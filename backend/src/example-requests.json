{
  "info": {
    "name": "Fleet Management API Examples",
    "description": "Exemplos de requisições para a API de Frota",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"securePassword123\",\n  \"name\": \"New User\",\n  \"role\": \"manager\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fleet.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Create Vehicle",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "YOUR_TOKEN_HERE",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plate\": \"XYZ9876\",\n  \"brand\": \"Mercedes\",\n  \"model\": \"Actros\",\n  \"year\": 2021,\n  \"color\": \"Cinza\",\n  \"transportType\": \"Rodoviário\",\n  \"chassisNumber\": \"XYZ987654321\",\n  \"loadCapacity\": 22000,\n  \"observations\": \"Caminhão frigorífico com compartimento refrigerado\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/vehicles",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "vehicles"]
            }
          }
        },
        {
          "name": "Get All Vehicles",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "YOUR_TOKEN_HERE",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/api/vehicles?active=true",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "vehicles"],
              "query": [
                {
                  "key": "active",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
